# Database (Railway: set from PostgreSQL service "Variables" → DATABASE_URL)
DATABASE_URL=postgres://user:password@localhost:5432/swiftdrop

# Auth (required in production; use a long random string)
JWT_SECRET=your_jwt_secret_here

# Server (Railway sets PORT automatically)
PORT=4000

# Optional: production
NODE_ENV=production

# Auth: require phone OTP verification before login/refresh (default: true).
# Set to false only for local/staging testing — do not use in real production.
# Skips OTP after register (API returns tokens), skips SMS on signup, and allows login without verify.
# REQUIRE_PHONE_VERIFICATION=false

# --- Optional: PayFast (payments) ---
# PAYFAST_MERCHANT_ID=your_merchant_id
# PAYFAST_MERCHANT_KEY=your_merchant_key
# PAYFAST_MERCHANT_ID and PAYFAST_MERCHANT_KEY are required for PayFast initiation.
# PAYFAST_RETURN_URL=https://yourapp.com/payfast/return
# PAYFAST_CANCEL_URL=https://yourapp.com/payfast/cancel
# PAYFAST_NOTIFY_URL=https://yourapp.com/payfast/notify (optional)
# PAYFAST_PASSPHRASE=your_passphrase (optional)
# PAYFAST_USE_SANDBOX=true (recommended for testing)

# --- Optional: SMSPortal (SMS/OTP) ---
# SMS/OTP delivery via SMSPortal REST API.
# Set these in Railway as environment variables; do NOT commit real secrets.
#
# SMSPORTAL_CLIENT_ID=your_smsportal_client_id
# SMSPORTAL_CLIENT_SECRET=your_smsportal_api_secret

# --- Optional: Firebase (push) ---
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your_project_id"}

# --- Optional: Cloudinary (image uploads) ---
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
# Or single URL: CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
