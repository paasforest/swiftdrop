          "apiKey": "AIzaSyCT28_D6Bc-cGPnpuHs85gWSvAu-XelE7Y"
        }
      }
    },
    "updates": {
      "enabled": false
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": [],
          "mode": "production"
        }
      ],
