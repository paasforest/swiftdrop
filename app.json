      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.swiftdrop.app",
      "config": {
        "googleMapsApiKey": "AIzaSyCT28_D6Bc-cGPnpuHs85gWSvAu-XelE7Y"
      }
    },
    "android": {
      "package": "com.swiftdrop.app",
      "softwareKeyboardLayoutMode": "resize",
