{
  "expo": {
    "name": "SwiftDrop",
    "slug": "swiftdrop",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A73E8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.swiftdrop.app",
      "config": {
        "googleMapsApiKey": "AIzaSyCT28_D6Bc-cGPnpuHs85gWSvAu-XelE7Y"
      }
    },
    "android": {
      "package": "com.swiftdrop.app",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCT28_D6Bc-cGPnpuHs85gWSvAu-XelE7Y"
        }
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": [],
          "mode": "production"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "28838eaa-a410-455a-9969-59929242e7e5"
      }
    },
    "owner": "swiftdrop26"
  }
}
